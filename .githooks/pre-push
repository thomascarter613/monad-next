#!/usr/bin/env bash
# Pre-push gate — mirrors CI's checks locally so a push that CI
# will red-X can't leave the machine in the first place. Runs the
# four commands CI runs, in the same order and with the same flags.
#
# Enable once per clone:
#
#     git config core.hooksPath .githooks
#
# Short-circuits (exit 0) if no Rust-relevant files are staged for
# push, so docs-only / markdown-only pushes skip the cargo cost.

set -euo pipefail

# Every ref being pushed arrives on stdin; we don't care WHICH ref,
# just whether Rust files have changed between the remote's current
# tip and the local commit about to land.
rust_changed=0
while read -r _local_ref local_sha _remote_ref remote_sha; do
    # Deletion push — remote_sha is the deleting side; nothing to check.
    if [[ "$local_sha" == "0000000000000000000000000000000000000000" ]]; then
        continue
    fi
    # First push of a branch — nothing on remote, check everything
    # in the new ref against the default branch instead.
    if [[ "$remote_sha" == "0000000000000000000000000000000000000000" ]]; then
        base="$(git merge-base "$local_sha" origin/main 2>/dev/null || true)"
        remote_sha="${base:-HEAD}"
    fi
    # Anything of interest in the diff?
    if git diff --name-only "$remote_sha" "$local_sha" 2>/dev/null \
        | grep -qE '^(Cargo\.(toml|lock)|crates/.*\.(rs|toml)|examples/.*\.(rs|toml))$'; then
        rust_changed=1
        break
    fi
done

if [[ "$rust_changed" -eq 0 ]]; then
    exit 0
fi

say() { printf '\n==> %s\n' "$*"; }
fail() {
    printf '\n\033[31m✗ pre-push failed:\033[0m %s\n' "$*" >&2
    printf '  skip this gate: \033[33mgit push --no-verify\033[0m (not recommended)\n' >&2
    exit 1
}

# Same flag set as .github/workflows/ci.yml. Order matches CI so
# the first thing to break locally is the first thing CI would flag.

say 'cargo fmt --check'
cargo fmt --all -- --check || fail "formatting — run: cargo fmt"

say 'cargo clippy --workspace --all-targets --locked'
RUSTFLAGS="-D warnings" \
    cargo clippy --workspace --all-targets --locked \
    || fail "clippy / lockfile — run: cargo check --workspace then retry"

say 'cargo build --workspace --locked'
cargo build --workspace --locked \
    || fail "build / lockfile — if you bumped a version, run cargo build"

say 'cargo test --workspace --locked'
cargo test --workspace --locked -- --test-threads=1 \
    || fail "tests"

printf '\n\033[32m✓ pre-push checks passed\033[0m\n'
